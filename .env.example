# ==============================================================================
# ESM Enterprise Platform — local environment overrides
# ==============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.
#
# All values are OPTIONAL — scripts fall back to built-in defaults when absent.
# For production use you MUST set INSTALL_SECRET and ADMIN_PASSWORD.
# ==============================================================================

# ------------------------------------------------------------------------------
# osTicket secrets (not stored in AWS Secrets Manager — must be set here or
# passed as --osticket-install-secret / --osticket-admin-password CLI args)
# ------------------------------------------------------------------------------
INSTALL_SECRET=put-a-long-random-string-here-please-change-me
ADMIN_PASSWORD=ChangeThisAdminPassword123!

# ------------------------------------------------------------------------------
# osTicket install / helpdesk identity (optional overrides)
# ------------------------------------------------------------------------------
# INSTALL_NAME=My Helpdesk
# INSTALL_URL=http://osticket.internal.esm.local
# INSTALL_EMAIL=helpdesk@example.com
# ADMIN_FIRSTNAME=Admin
# ADMIN_LASTNAME=User
# ADMIN_EMAIL=admin@example.com
# ADMIN_USERNAME=ostadmin
# CRON_INTERVAL=5

# ------------------------------------------------------------------------------
# Moodle admin identity (optional overrides — defaults are fine for most uses)
# ------------------------------------------------------------------------------
# MOODLE_ADMIN_USER=admin
# MOODLE_ADMIN_PASSWORD=Admin~1234
# MOODLE_ADMIN_EMAIL=admin@esmos.meals.sg
# MOODLE_URL=http://moodle.internal.esm.local

# ------------------------------------------------------------------------------
# Secret IDs in AWS Secrets Manager (override if you rename them)
# ------------------------------------------------------------------------------
# ODOO_DB_SECRET_ID=esm/prod/odoo-db-password
# MOODLE_DB_SECRET_ID=esm/prod/moodle-db-password
# OSTICKET_DB_SECRET_ID=esm/prod/osticket-db-password

# ------------------------------------------------------------------------------
# osTicket ECR image + DB overrides (resolved at runtime when absent)
# ------------------------------------------------------------------------------
# OSTICKET_IMAGE=<account>.dkr.ecr.ap-southeast-1.amazonaws.com/esm/osticket:<tag>
# OSTICKET_DB_USER=moodle_admin
# OSTICKET_DB_NAME=osticketdb
# OSTICKET_DB_HOST=
